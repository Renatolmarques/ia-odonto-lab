# IA Odonto Lab — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# PostgreSQL (local Docker — pgvector)
DB_HOST=db
DB_PORT=5432
DB_NAME=ia_odonto
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST_LOCAL=localhost
DB_PORT_LOCAL=5433
DATABASE_URL=postgresql://postgres:postgres@db:5432/ia_odonto

# EspoCRM
ESPO_URL=https://your-crm-domain.com
ESPO_API_KEY=your-espocrm-api-key

# App
APP_ENV=development
LOG_LEVEL=INFO
